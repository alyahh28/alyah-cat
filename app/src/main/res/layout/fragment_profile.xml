<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".Profile.ProfileFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <View
            android:id="@+id/headerView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_header_wave"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toTopOf="parent"
            app:title="Profil Saya"
            app:titleTextColor="@android:color/white" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfile"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_marginTop="120dp"
            android:background="#FFFFFF"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:src="@drawable/alyah"
            android:elevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/Widget.Material3.CircularProgressIndicator" />

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Alyah Najwa Restu Islami"
            android:textColor="#1E293B"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ivProfile" />

        <TextView
            android:id="@+id/tvProdi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sistem Informasi"
            android:textColor="#64748B"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvName" />

        <TextView
            android:id="@+id/tvKampus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Politeknik Caltex Riau"
            android:textColor="#0084FF"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvProdi" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@+id/tvKampus">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:text="Social Media"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInstagram"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#E1306C"
                    android:text="Instagram"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_camera" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLinkedIn"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#0077B5"
                    android:text="LinkedIn"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_share" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGithub"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:backgroundTint="#333333"
                    android:text="GitHub"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_info_details" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>