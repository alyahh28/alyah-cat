<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FA"
    tools:context=".Home.pertemuan_8.DelpanActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_blue_gradient"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Layanan Bina Desa"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Form Laporan Layanan"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_form_desa"
                android:orientation="vertical"
                android:padding="16dp"
                android:elevation="4dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tlNama"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nama Pelapor"
                    app:boxStrokeColor="#1976D2"
                    app:hintTextColor="#1976D2"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="#1976D2">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNama"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tlLaporan"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Detail Laporan"
                    app:boxStrokeColor="#1976D2"
                    app:hintTextColor="#1976D2"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:startIconTint="#1976D2">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLaporan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:lines="3" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKirim"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="20dp"
                    android:text="Kirim Laporan"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1976D2"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_send"
                    app:iconGravity="textStart" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Kategori Laporan:"
                android:textColor="#0D47A1"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipInfrastruktur"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Infrastruktur"
                    app:chipBackgroundColor="@android:color/white"
                    app:chipStrokeColor="#1976D2" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipKesehatan"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kesehatan" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipKeamanan"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keamanan" />
            </com.google.android.material.chip.ChipGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Menu Cepat"
                android:textColor="#0D47A1"
                android:textStyle="bold" />

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/gridLayoutMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:columnCount="2"
                app:alignmentMode="alignMargins">

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Ambulan"
                    android:textColor="#1976D2"
                    app:strokeColor="#1976D2"
                    app:layout_columnWeight="1"
                    android:layout_margin="4dp"/>

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Damkar"
                    android:textColor="#1976D2"
                    app:strokeColor="#1976D2"
                    app:layout_columnWeight="1"
                    android:layout_margin="4dp"/>

            </androidx.gridlayout.widget.GridLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>